#!/bin/zsh
# Clear problematic env vars that cause terminal response timeouts in tmux popups
unset KITTY_WINDOW_ID
unset KITTY_PID
unset TERM_PROGRAM
export TERM=xterm-256color
tmp=$(mktemp)
yazi --chooser-file="$tmp" 2>/dev/null
if [ -s "$tmp" ]; then
    file=$(cat "$tmp")
    mime=$(file --mime-type -b "$file")
    case "$mime" in
        text/*|application/json|application/xml|inode/x-empty)
            tmux send-keys -t :1 "hx $(printf '%q' "$file")" Enter ;;
        *)
            if [[ "$(uname)" == "Darwin" ]]; then
                open "$file"
            else
                xdg-open "$file" &>/dev/null &
            fi ;;
    esac
fi
rm -f "$tmp"
